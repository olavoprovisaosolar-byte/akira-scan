{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "../../dist",
    "rootDir": "..",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "esModuleInterop": true
  },
  "include": [
    "../shared/**/*.ts",
    "../core/**/*.ts",
    "../infrastructure/**/*.ts",
    "../services/**/*.ts",
    "./**/*.ts"
  ]
}
