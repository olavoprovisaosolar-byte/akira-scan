{
  "name": "akirascan",
  "private": true,
  "type": "module",
  "version": "2.0.0",
  "description": "AkiraScan — plataforma poliglota de leitura de mangás",
  "scripts": {
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p src/server/tsconfig.json",
    "build:client": "tsc -p src/client/tsconfig.json",
    "dev": "npm run build && tsx api/src/server.ts",
    "dev:legacy": "node scripts/dev-server.mjs",
    "sync:py": "python sync/python/toonlivre_sync.py",
    "sync:node": "node scripts/sync-toonlivre.mjs",
    "sync": "npm run sync:py || npm run sync:node",
    "backup:toonlivre": "node scripts/backup-toonlivre-full.mjs",
    "backup:chapters": "node scripts/backup-chapters.mjs",
    "backup:complete": "node scripts/backup-toonlivre-complete.mjs",
    "backup:turbo": "node scripts/backup-turbo.mjs",
    "backup:parallel": "node scripts/backup-parallel.mjs",
    "sync:chapters": "node scripts/sync-chapters-backup.mjs",
    "backup:toonlivre:meta": "node scripts/backup-toonlivre-full.mjs --meta-only",
    "import:backup": "node scripts/import-toonlivre-backup.mjs",
    "build:catalog-index": "node scripts/build-catalog-index.mjs",
    "rebuild:backup": "node scripts/rebuild-from-backup.mjs",
    "deploy:prod": "node scripts/deploy-prod.mjs",
    "prepare:github": "node scripts/prepare-github-deploy.mjs",
    "deploy:github": "node scripts/prepare-github-deploy.mjs",
    "terabox:build-index": "node scripts/build-terabox-chapters-index.mjs",
    "terabox:build-index:dlinks": "node scripts/build-terabox-chapters-index.mjs --dlinks --limit=100",
    "terabox:sync-deploy": "node scripts/sync-cloud-index-deploy.mjs",
    "cloud:link-caps": "node scripts/build-terabox-chapters-index.mjs --refresh-dlinks --dlinks --only-purged --limit=250",
    "cloud:link-all": "node scripts/build-terabox-chapters-index.mjs --refresh-dlinks --dlinks --only-purged",
    "prepare:firebase": "node scripts/prepare-firebase-deploy.mjs",
    "deploy:firebase": "node scripts/deploy-firebase.mjs",
    "optimize:webp": "node scripts/convert-images-webp.mjs",
    "verify:chapters": "node scripts/verify-chapters.mjs --api",
    "terabox:sync": "node scripts/terabox/sync.mjs",
    "terabox:upload": "node scripts/terabox/upload.mjs",
    "terabox:upload-all": "node scripts/terabox/upload-all.mjs",
    "terabox:upload:fast": "node scripts/terabox/upload-fast.mjs",
    "terabox:upload:stable": "node scripts/terabox/upload-stable.mjs",
    "terabox:upload:turbo": "node scripts/terabox/upload-fast.mjs",
    "terabox:purge": "node scripts/terabox/purge-local.mjs",
    "terabox:pipeline": "node scripts/terabox/pipeline.mjs",
    "terabox:check": "node scripts/terabox/sync.mjs --check",
    "terabox:link-existing": "node scripts/terabox/link-existing.mjs",
    "terabox:link-existing:dry": "node scripts/terabox/link-existing.mjs --dry-run",
    "verify:terabox": "node scripts/verify-terabox-link.mjs",
    "verify:terabox:live": "node scripts/verify-terabox-link.mjs --live --sample=12",
    "typecheck": "npm run build && tsc -p tsconfig.json --noEmit && tsc -p api/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "integrity:check": "tsx src/scripts/checkIntegrity.ts",
    "seed:db": "tsx src/scripts/seedDatabase.ts",
    "api:build": "tsc -p api/tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "firebase-tools": "^15.22.4",
    "playwright": "^1.61.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@netlify/blobs": "^10.7.9",
    "axios": "^1.18.1",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "firebase-admin": "^13.10.0",
    "terabox-api": "^2.9.2"
  },
  "engines": {
    "node": ">=20"
  }
}
