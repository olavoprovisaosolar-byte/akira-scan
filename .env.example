# ── Terabox (AkiraScan worker) ─────────────────────────────────────────────
# Obtenha o token ndus: DevTools → Application → Cookies → terabox.com → ndus
TERABOX_NDUS=

# Alternativa: cookie completo de sessão (ndus=... será extraído automaticamente)
TERABOX_COOKIE=

# Pasta remota onde os mangás ficam no Terabox
TERABOX_REMOTE_DIR=/meus_mangas

# Delay mínimo entre chamadas à API (evita bloqueio por bot)
TERABOX_DELAY_MS=3000

# Criar links de compartilhamento ao sincronizar (1 = sim, 0 = não)
TERABOX_CREATE_SHARES=0

# Sincronização recursiva (1 = inclui subpastas/arquivos)
TERABOX_RECURSIVE=0
