# Variáveis de ambiente — AkiraScan
# Copie para .env e preencha conforme necessário.

# Bot NexusToons — hospedagem
# TELEGRA_UPLOAD_URL=https://telegra.ph/upload
# TELEGRA_DELAY_MS=600
# TELEGRA_SKIP=1
# NEXUSTOONS_HOSTING_ADAPTER=cloud-static

# API Cloudflare — publicação automática de capítulos (R2)
# AKIRA_PUBLISH_TOKEN=seu-token-secreto
# AKIRA_PUBLISH_BASE_URL=https://akira-scan.pages.dev
# AKIRA_SCAN_BASE_URL=https://akira-scan.pages.dev
# AKIRA_PUBLISH_API=1

# Cloudflare deploy (CI/local)
# CLOUDFLARE_API_TOKEN=
# CF_PAGES_PROJECT=akira-scan

# Netlify Blobs (API de utilizadores)
# NETLIFY_BLOBS_CONTEXT=dev
