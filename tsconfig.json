{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "lib": ["ES2022", "DOM"]
  },
  "include": [
    "shared/**/*.ts",
    "js/types/**/*.d.ts"
  ]
}
