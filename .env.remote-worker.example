# Worker remoto (segundo PC) — NexusToons → Telegra.ph
# Copie para .env:  copy .env.remote-worker.example .env

# Nome deste PC (aparece nos commits git)
REMOTE_WORKER_NAME=pc-casa

# Git commit author (sem git config global)
GIT_AUTHOR_NAME=pc-casa
GIT_AUTHOR_EMAIL=seu@email.com

# Hosting Telegra (primário)
HOSTING_ADAPTER=telegra
NEXUSTOONS_HOSTING_ADAPTER=telegra
TELEGRA_SKIP=0
TELEGRA_STATIC_FALLBACK=true
TELEGRA_DELAY_MS=600
TELEGRA_RETRIES=3

# Captura NexusToons
NEXUSTOONS_USE_PLAYWRIGHT=1
NEXUSTOONS_BASE_URL=https://nexustoons.com

# RAM baixa no segundo PC (lite usa 1 browser)
STREAM_PAGE_CONCURRENCY=2

# Sync git a cada N minutos (push checkpoint para GitHub)
SYNC_INTERVAL_MINUTES=15

# Opcional: sync índice remoto no site
# AKIRA_PUBLISH_TOKEN=
# AKIRA_PUBLISH_BASE_URL=https://akira-scan.pages.dev
