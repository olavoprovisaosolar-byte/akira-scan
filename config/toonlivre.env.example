# ToonLivre — credenciais oficiais (contrato)
# Copie para .env ou defina no Netlify / servidor

TOONLIVRE_BASE_URL=https://toonlivre.net
TOONLIVRE_TOKEN_HEADER=x-tly-sec
TOONLIVRE_TOKEN_VALUE=
TOONLIVRE_API_KEY=

# Sync
TOONLIVRE_SYNC_PAGES=10
TOONLIVRE_SYNC_DETAIL=120

# Proxy cache (Firestore — produção)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
PROXY_CACHE_TTL_MS=86400000

# MangaLivre
MANGALIVRE_BASE_URL=https://mangalivre.net
